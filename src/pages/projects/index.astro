---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = await getCollection("projects");

// Extract all unique tags dynamically for the filter bar
const tagCounts = projects.flatMap(post => post.data.tags || []).reduce((acc: Record<string, number>, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
}, {} as Record<string, number>);

const allTags = Object.keys(tagCounts).sort();
---

<BaseLayout
    title="projects."
    description="The directory consisting of my personal projects, academic projects and UDGRPs.">

    <div class="not-prose mb-10 space-y-6">
        <h1 class="tracking-widest font-mono">projects.</h1>
        <p class="text-text-muted">Filter by category or tag to check out my personal coding projects, UDGRPs, and academic projects!</p>

        {/* Filter Control Panel */}
        <div class="bg-bg-surface border border-text-muted/30 p-5 rounded-xl flex flex-col gap-5">
            <div class="flex flex-col sm:flex-row justify-between gap-4">
                {/* Category Filters */}
                <div class="flex flex-wrap gap-2 items-center" id="type-filters">
                    <span class="text-sm font-bold text-brand-dark uppercase tracking-widest mr-2">Type:</span>
                    <button class="filter-btn active px-3 py-1 text-sm rounded border border-brand bg-brand/10 text-brand-light transition-colors" data-type="all">All</button>
                    <button class="filter-btn px-3 py-1 text-sm rounded border border-text-muted/30 text-text-muted hover:border-brand-light hover:text-brand-light transition-colors" data-type="academic">Academic</button>
                    <button class="filter-btn px-3 py-1 text-sm rounded border border-text-muted/30 text-text-muted hover:border-brand-light hover:text-brand-light transition-colors" data-type="udgrp">UDGRP</button>
                    <button class="filter-btn px-3 py-1 text-sm rounded border border-text-muted/30 text-text-muted hover:border-brand-light hover:text-brand-light transition-colors" data-type="personal">Personal</button>
                </div>

                {/* Tag Dropdown for Mobile Friendliness */}
                {allTags.length > 0 && (
                    <div class="flex items-center gap-2" id="tag-filters">
                        <label for="tag-select" class="text-sm font-bold text-brand-dark uppercase tracking-widest hidden sm:block">Tag:</label>
                        
                        <div class="relative flex items-center">
                            <select 
                                id="tag-select" 
                                class="bg-bg-main border border-text-muted/30 text-text-main text-sm rounded py-1.5 pl-3 pr-10 focus:border-brand outline-none cursor-pointer hover:border-brand-light transition-colors max-w-[180px] truncate appearance-none"
                            >
                                <option value="all">All Tags</option>
                                {allTags.map(tag => (
                                    <option value={tag}>{tag} ({tagCounts[tag]})</option>
                                ))}
                            </select>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3 pointer-events-none text-text-muted">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>
                    </div>
                )}
            </div>

            {/* Dynamic Category Explanation */}
            <div class="border-t border-text-muted/20 pt-3">
                <p id="category-description" class="text-sm text-text-muted italic m-0 transition-opacity duration-300">
                    Showing all projects, including academic projects, UDGRPs, and independent developments.
                </p>
            </div>
        </div>
    </div>

    {/* Project Grid */}
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-6" id="project-grid">
        {
            projects.map((post) => (
                <div 
                    class="project-item transition-all duration-500 ease-in-out" 
                    data-type={post.data.projectType} 
                    data-tags={post.data.tags?.join(',')}
                >
                    <ProjectCard
                        title={post.data.cardTitle}
                        href={`/projects/${post.id}`}
                        description={post.data.description}
                        backgroundImage={post.data.backgroundImage}
                        tags={post.data.tags}
                        timeline={post.data.timeline}
                        role={post.data.role}
                        institution={post.data.institution}
                        supervisor={post.data.supervisor}
                    />
                </div>
            ))
        }
    </div>

    {/* No Results Message (Hidden by default) */}
    <div id="no-results" class="hidden text-center py-10 text-text-muted italic">
        No projects found matching the selected filters.
    </div>

</BaseLayout>

<script>
    document.addEventListener("astro:page-load", () => {
        let currentType = 'all';
        let currentTag = 'all';

        const items = document.querySelectorAll('.project-item');
        const typeBtns = document.querySelectorAll('.filter-btn');
        const tagSelect = document.getElementById('tag-select') as HTMLSelectElement;
        const noResults = document.getElementById('no-results');
        const descText = document.getElementById('category-description');

        // The text for each category
        const descriptions = {
            'all': 'Showing all projects, including academic projects, personal projects and UDGRPs.',
            'academic': 'Formal academic projects undertaken under the guidance of professors or academic institutions.',
            'udgrp': 'Undergraduate Directed Reading Programs (UDGRP) of the Math Club, ISI Bengaluru Centre, involving group reading projects with peers.',
            'personal': 'Cool stuff I made!'
        };

        function filterProjects() {
            let visibleCount = 0;

            items.forEach((item) => {
                const itemType = item.getAttribute('data-type');
                const itemTags = item.getAttribute('data-tags')?.split(',') || [];
                
                const typeMatch = currentType === 'all' || itemType === currentType;
                const tagMatch = currentTag === 'all' || itemTags.includes(currentTag);

                if (typeMatch && tagMatch) {
                    item.classList.remove('hidden');
                    setTimeout(() => item.classList.remove('opacity-0', 'scale-95'), 10);
                    visibleCount++;
                } else {
                    item.classList.add('opacity-0', 'scale-95');
                    setTimeout(() => item.classList.add('hidden'), 300);
                }
            });

            if (noResults) {
                visibleCount === 0 ? noResults.classList.remove('hidden') : noResults.classList.add('hidden');
            }
        }

        function updateUI() {
            // Update buttons
            typeBtns.forEach(btn => {
                if (btn.getAttribute('data-type') === currentType) {
                    btn.classList.replace('border-text-muted/30', 'border-brand');
                    btn.classList.replace('text-text-muted', 'text-brand-light');
                    btn.classList.add('bg-brand/10');
                } else {
                    btn.classList.replace('border-brand', 'border-text-muted/30');
                    btn.classList.replace('text-brand-light', 'text-text-muted');
                    btn.classList.remove('bg-brand/10');
                }
            });

            // Update dropdown value
            if (tagSelect) tagSelect.value = currentTag;

            // Update description text with a smooth fade
            if (descText) {
                descText.style.opacity = '0';
                setTimeout(() => {
                    descText.textContent = descriptions[currentType as keyof typeof descriptions];
                    descText.style.opacity = '1';
                }, 150);
            }
        }

        // Top Panel Type Buttons
        typeBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                currentType = (e.target as HTMLElement).getAttribute('data-type') || 'all';
                updateUI();
                filterProjects();
            });
        });

        // Top Panel Dropdown Change
        if (tagSelect) {
            tagSelect.addEventListener('change', (e) => {
                currentTag = (e.target as HTMLSelectElement).value;
                filterProjects();
            });
        }

        // Clicking a tag directly on a project card
        document.querySelectorAll('.project-tag').forEach(cardTag => {
            cardTag.addEventListener('click', (e) => {
                e.preventDefault(); 
                currentTag = (e.target as HTMLElement).getAttribute('data-tag') || 'all';
                updateUI();
                filterProjects();
                document.getElementById('type-filters')?.scrollIntoView({ behavior: 'smooth', block: 'end' });
            });
        });
    });
</script>
