---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blogs"))
    .sort((a, b) => {
        return (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0);
    });


// Extract tags and count their occurrences
const tagCounts = posts.flatMap(post => post.data.tags || []).reduce((acc: Record<string, number>, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
}, {} as Record<string, number>);

// Dynamically extract unique tags, series and types.
const allTags = Object.keys(tagCounts).sort(); // Keep them sorted alphabetically
const allSeries = [...new Set(posts.map(post => post.data.series).filter(Boolean))].sort();
const allTypes = [...new Set(posts.map(post => post.data.type).filter(Boolean))].sort();
---

<BaseLayout title="blog." description="A personal notepad of thoughts, and expression">
    <div class="not-prose mb-10 space-y-6">
        <h1 class="tracking-widest font-mono">blog.</h1>
        <p class="text-text-muted">A personal notepad of thoughts, and expression.</p>

        {/* Filter Control Panel */}
        <div class="bg-bg-surface border border-text-muted/30 p-5 rounded-xl flex flex-col gap-5">
            
            <div class="flex flex-col xl:flex-row justify-between gap-6">
{/* Dynamic Type Buttons (Anchors the Left Side) */}
                <div class="flex flex-wrap gap-2 items-center" id="type-filters">
                    <span class="text-sm font-bold text-brand-dark uppercase tracking-widest mr-2">Type:</span>
                    <button class="filter-btn active px-3 py-1 text-sm rounded border border-brand bg-brand/10 text-brand-light transition-colors" data-type="all">All</button>
                    {allTypes.map(type => (
                        <button class="filter-btn px-3 py-1 text-sm rounded border border-text-muted/30 text-text-muted hover:border-brand-light hover:text-brand-light transition-colors capitalize" data-type={type}>
                            {type}
                        </button>
                    ))}
                </div>

                {/* Dropdowns (Anchors the Right Side) */}
                <div class="flex flex-wrap items-center gap-4">
                    {allTags.length > 0 && (
                        <div class="flex items-center gap-2">
                            <label for="tag-select" class="text-sm font-bold text-brand-dark uppercase tracking-widest hidden sm:block">Tag:</label>
                            
                            {/* Relative wrapper to hold our custom arrow */}
                            <div class="relative flex items-center">
                                <select id="tag-select" class="bg-bg-main border border-text-muted/30 text-text-main text-sm rounded py-1.5 pl-3 pr-10 focus:border-brand outline-none cursor-pointer hover:border-brand-light transition-colors max-w-[180px] truncate appearance-none">
                                    <option value="all">All Tags</option>
                                    {allTags.map(tag => (
                                        <option value={tag}>{tag} ({tagCounts[tag]})</option>
                                    ))}
                                </select>
                                {/* The custom arrow overlay */}
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3 pointer-events-none text-text-muted">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </div>
                        </div>
                    )}

                    {allSeries.length > 0 && (
                        <div class="flex items-center gap-2">
                            <label for="series-select" class="text-sm font-bold text-brand-dark uppercase tracking-widest hidden sm:block">Series:</label>
                            
                            {/* Relative wrapper to hold our custom arrow */}
                            <div class="relative flex items-center">
                                <select id="series-select" class="bg-bg-main border border-text-muted/30 text-text-main text-sm rounded py-1.5 pl-3 pr-10 focus:border-brand outline-none cursor-pointer hover:border-brand-light transition-colors max-w-[200px] truncate appearance-none">
                                    <option value="all">All Series</option>
                                    {allSeries.map(series => <option value={series}>{series}</option>)}
                                </select>
                                {/* The custom arrow overlay */}
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3 pointer-events-none text-text-muted">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </div>
                        </div>
                    )}
                </div>
            </div>
        </div>

    {/* Blog Grid */}
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-8 w-full lg:grid-cols-3" id="blog-grid">
        {
            posts.map((post) => (
                <div 
                    class="blog-item transition-all duration-500 ease-in-out" 
                    data-tags={post.data.tags?.join(',')}
                    data-series={post.data.series || ''}
                    data-type={post.data.type || ''}
                >
                    <BlogCard
                        title={post.data.title}
                        href={`/blog/${post.id}`}
                        date={post.data.pubDate}
                        description={post.data.description}
                        backgroundImage={post.data.backgroundImage}
                        tags={post.data.tags}
                        series={post.data.series} 
                    />
                </div>
            ))
        }
    </div>

    {/* No Results Message */}
    <div id="no-results" class="hidden text-center py-10 text-text-muted italic">
        No posts found matching the selected filters.
    </div>

</BaseLayout>

{/* Filtering Logic */}
<script>
    document.addEventListener("astro:page-load", () => {
        let currentType = 'all'; // Track the active type
        let currentTag = 'all';
        let currentSeries = 'all';

        const items = document.querySelectorAll('.blog-item');
        const typeBtns = document.querySelectorAll('.filter-btn'); // Grab the type buttons
        const tagSelect = document.getElementById('tag-select') as HTMLSelectElement;
        const seriesSelect = document.getElementById('series-select') as HTMLSelectElement;
        const noResults = document.getElementById('no-results');

        function filterBlogs() {
            let visibleCount = 0;

            items.forEach((item) => {
                const itemType = item.getAttribute('data-type');    
                const itemTags = item.getAttribute('data-tags')?.split(',') || [];
                const itemSeries = item.getAttribute('data-series');
                
                // Check if the item matches the active filters
                const typeMatch = currentType === 'all' || itemType === currentType;
                const tagMatch = currentTag === 'all' || itemTags.includes(currentTag);
                const seriesMatch = currentSeries === 'all' || itemSeries === currentSeries;

                // Must match ALL THREE filters to be visible
                if (typeMatch && tagMatch && seriesMatch) {
                    item.classList.remove('hidden');
                    setTimeout(() => item.classList.remove('opacity-0', 'scale-95'), 10);
                    visibleCount++;
                } else {
                    item.classList.add('opacity-0', 'scale-95');
                    setTimeout(() => item.classList.add('hidden'), 300);
                }
            });

            if (noResults) {
                visibleCount === 0 ? noResults.classList.remove('hidden') : noResults.classList.add('hidden');
            }
        }

        // Handle Type Button Clicks and UI styling
        typeBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                currentType = (e.target as HTMLElement).getAttribute('data-type') || 'all';
                
                // Style the active/inactive buttons
                typeBtns.forEach(b => {
                    if (b.getAttribute('data-type') === currentType) {
                        b.classList.replace('border-text-muted/30', 'border-brand');
                        b.classList.replace('text-text-muted', 'text-brand-light');
                        b.classList.add('bg-brand/10');
                    } else {
                        b.classList.replace('border-brand', 'border-text-muted/30');
                        b.classList.replace('text-brand-light', 'text-text-muted');
                        b.classList.remove('bg-brand/10');
                    }
                });
                
                filterBlogs();
            });
        });

        if (tagSelect) {
            tagSelect.addEventListener('change', (e) => {
                currentTag = (e.target as HTMLSelectElement).value;
                filterBlogs();
            });
        }

        if (seriesSelect) {
            seriesSelect.addEventListener('change', (e) => {
                currentSeries = (e.target as HTMLSelectElement).value;
                filterBlogs();
            });
        }

        document.querySelectorAll('.project-tag').forEach(cardTag => {
            cardTag.addEventListener('click', (e) => {
                e.preventDefault(); 
                currentTag = (e.target as HTMLElement).getAttribute('data-tag') || 'all';
                if (tagSelect) tagSelect.value = currentTag;
                filterBlogs();
                document.querySelector('.not-prose')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });
    });
</script>
