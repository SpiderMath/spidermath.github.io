---
interface Props {
    title: string;
    href: string;
    description?: string;
    date?: Date;
    backgroundImage?: string;
    tags?: string[];
    upperBadge?: string;
    role?: string;
    institution?: string;
    supervisor?: string;
}

const {
    title, href, description, date, backgroundImage, 
    tags, upperBadge, role, institution, supervisor
} = Astro.props;

const formattedDate = date?.toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
});

const cardBackground = backgroundImage 
    ? "bg-transparent" 
    : "bg-gradient-to-br from-bg-surface via-bg-surface to-[var(--color-brand-dark)]/10";
---

<a 
    href={href} 
    class=`group relative flex flex-col justify-between ${cardBackground} border border-text-muted/30 rounded-xl p-6 transition-all duration-300 hover:border-brand hover:-translate-y-1 hover:shadow-lg hover:shadow-brand/10 no-underline h-full overflow-hidden min-h-[280px]`
>
    {backgroundImage && (
        <div class="absolute inset-0 z-0 overflow-hidden rounded-xl">
            <div
                class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
                style={`background-image: url(${backgroundImage})`}
            ></div>
            <div class="absolute inset-0 bg-bg-main/85 backdrop-blur-sm transition-opacity duration-300 group-hover:bg-bg-main/75"></div>
        </div>
    )}

    <div class="relative z-10 flex flex-col h-full">
        <div>
            {/* Upper Badge / Timeline */}
            {(upperBadge || formattedDate) && (
                <div class="text-xs font-mono text-brand-light/80 mb-2 uppercase tracking-wider">
                    {upperBadge || formattedDate}
                </div>
            )}

            <h3 class="text-xl font-bold text-text-main group-hover:text-brand transition-colors duration-300 mb-2 mt-0 leading-tight">
                {title}
            </h3>

            {/* Academic Meta Info */}
            {(role || institution || supervisor) && (
                <div class="text-xs text-text-muted mb-3 space-y-1 font-mono">
                    {role && <div><span class="text-brand-dark">Role:</span> {role}</div>}
                    {institution && <div><span class="text-brand-dark">Inst:</span> {institution}</div>}
                    {supervisor && <div><span class="text-brand-dark">Supr:</span> {supervisor}</div>}
                </div>
            )}
            
            {description && (
                <p class="text-sm text-text-muted line-clamp-3 leading-relaxed mt-0">
                    {description}
                </p>
            )}
        </div>

        {/* Tags Section */}
        {tags && tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
                {tags.map((tag) => (
                    <button 
                        class="project-tag z-20 relative text-xs px-2 py-1 rounded border border-text-muted/30 text-text-muted hover:border-brand-light hover:text-brand-light hover:bg-bg-surface transition-all duration-300 cursor-pointer"
                        data-tag={tag}
                        aria-label={`Filter by ${tag}`}
                    >
                        #{tag}
                    </button>
                ))}
            </div>
        )}
    </div>
</a>